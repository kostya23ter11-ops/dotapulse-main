# DotaPulse environment variables
# Copy: npm run setup:env   (creates .env.local + generates secrets)
# Check: npm run check:env

# === Required for production ===

# Secret for signing auth JWT tokens (≥32 chars). npm run setup:env generates one.
AUTH_SECRET=replace_with_long_random_string_32plus_chars

# Base URL for Steam OpenID redirects (realm + callback).
# Production (Vercel): https://dotapulse-main.vercel.app
# Local dev:           http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# === Recommended ===

# Steam Web API key — player names/avatars + auth callback
# https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# Groq — AI chat + news enrichment (free tier)
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Alternative to Groq:
# OPENAI_API_KEY=sk-...

# Protects /api/cron/refresh-news. Vercel sends Authorization: Bearer <CRON_SECRET> on cron invocations.
CRON_SECRET=super_random_string_here

# === Admin Panel ===
# Comma-separated Steam IDs of admin users (64-bit format).
# Get your Steam ID: https://steamid.io/
# Example: ADMIN_STEAM_IDS=76561198012345678,76561198098765432
ADMIN_STEAM_IDS=

# === Optional: Vercel KV (shared cache & rate limit on production) ===
# Vercel Dashboard → Storage → Create Database → KV (auto-injects vars)
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...
#
# Or Upstash Redis directly:
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...